{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{{CODEX_CACHE_PLUGIN_ROOT}}/scripts/notify.py\" \"Codex\" \"Response ready\" --no-wait --quiet --best-effort",
            "commandWindows": "python \"{{CODEX_CACHE_PLUGIN_ROOT_WINDOWS}}\\scripts\\notify.py\" \"Codex\" \"Response ready\" --no-wait --quiet --best-effort",
            "timeout": 15,
            "statusMessage": "Sending notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{{CODEX_CACHE_PLUGIN_ROOT}}/scripts/notify.py\" \"Codex\" \"Permission required\" --no-wait --quiet --best-effort",
            "commandWindows": "python \"{{CODEX_CACHE_PLUGIN_ROOT_WINDOWS}}\\scripts\\notify.py\" \"Codex\" \"Permission required\" --no-wait --quiet --best-effort",
            "timeout": 15,
            "statusMessage": "Sending notification"
          }
        ]
      }
    ]
  }
}
