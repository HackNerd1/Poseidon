{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.py\" \"Claude Code\" \"Response ready\"",
            "timeout": 35,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.py\" \"Claude Code\" \"Claude is asking a question — input needed\"",
            "timeout": 35,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.py\" \"Claude Code\" \"Permission required — Claude needs your approval\"",
            "timeout": 35,
            "async": true
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.py\" \"Claude Code\" \"Claude is idle — waiting for your next prompt\"",
            "timeout": 35,
            "async": true
          }
        ]
      }
    ]
  }
}
